package community;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.ArrayList;


public class BoardDAO {
	
	private Connection conn;
	private ResultSet rs;
	
	//1) 접속하기위한 생성자 => crud할때마다 접속해야되는 불편함 그래서 @Autowired
	public BoardDAO() {
		try {
			String dbURL ="jdbc:oracle:thin:@localhost:1521/xe";
			String dbID = "TWO_U";
			String dbPassword = "1234";
			Class.forName("oracle.jdbc.OracleDriver");
			conn = DriverManager.getConnection(dbURL, dbID, dbPassword);
		}catch(Exception e) {
			e.printStackTrace();
		}
	}
	
	//2)작성일자를 구하는 메소드
	public String getDate() {
		String sql = "select now()";
		try {
			//대기 및 설정
			PreparedStatement pstmt = conn.prepareStatement(sql);
			rs = pstmt.executeQuery();
			if(rs.next()) {
				return rs.getString(1);
			}
		}catch(Exception e) {
			e.printStackTrace();
		}
		return "";//데이터 베이스 오류
	}
	
	//게시글 번호 부여 메소드
	public int getNext() {
		int num=0;//오라클 시퀀스 초기화
		String sql = "select IDX_SEQ.NEXTVAL from dual";
		//mysql => select idx from board order by idx desc;
		try {
			PreparedStatement pstmt = conn.prepareStatement(sql);
			rs=pstmt.executeQuery();
			if(rs.next()) {
				return rs.getInt("nextval");
			}
			return num;
		}catch (Exception e) {
			e.printStackTrace();
		}
		return -1;
	}
	

	//글쓰기 메소드 [글제목,사용자ID,글내용을 전달받아 DB에 새로운 데이터를 입력]
	public int write(String writer, String subject, String content) {
		String sql = "insert into BOARD_TBL values(?, ?, ?, ?, ?)";
		try {
			PreparedStatement pstmt = conn.prepareStatement(sql);
			pstmt.setInt(1,  getNext());//수동증가
			pstmt.setString(2,  writer);
			pstmt.setString(3, subject);
			pstmt.setString(4, content);//존재하는 시간을 가져오기 때문에
			pstmt.setString(5, getDate());
			return pstmt.executeUpdate();
		}catch (Exception e) {
			e.printStackTrace();
		}
		return -1; //데이터 베이스 오류
	}
	
	//list
	public ArrayList<Board> getList(){
		String sql = "select * from BOARD_TBL";
		ArrayList<Board> list = new ArrayList<Board>();
		
		try {
			PreparedStatement pstmt = conn.prepareStatement(sql);
			rs = pstmt.executeQuery();
			while (rs.next()) {
				Board board = new Board();//여는 태그
				board.setIdx(rs.getInt(1));//columnIndex;
				board.setWriter(rs.getString(2));
				board.setSubject(rs.getString(3));
				board.setContent(rs.getString(4));
				board.setDate(rs.getString(5));
				list.add(board);//닫는 태그
			}			
		}catch(Exception e) {
			e.printStackTrace();
		}
		return list;
	}
	
	/*
	private int idx;
	private String writer;
	private String subject;
	private String content;
	private String date;
	*/
	
	

}
